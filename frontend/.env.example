# ── Chain ──────────────────────────────────────────────
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws

# ── Deployer (contracts) ───────────────────────────────
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# ── Verification ───────────────────────────────────────
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# ── Frontend public vars ───────────────────────────────
# Populate these after running the deploy script.
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

NEXT_PUBLIC_RITUAL_TOKEN=0x_DEPLOYED_RITUAL_ADDRESS
NEXT_PUBLIC_SEP_ETH_TOKEN=0x_DEPLOYED_SEPETH_ADDRESS
NEXT_PUBLIC_BASE_ETH_TOKEN=0x_DEPLOYED_BASEETH_ADDRESS
NEXT_PUBLIC_USDT_TOKEN=0x_DEPLOYED_USDT_ADDRESS
NEXT_PUBLIC_USDC_TOKEN=0x_DEPLOYED_USDC_ADDRESS
NEXT_PUBLIC_AMM_ADDRESS=0x_DEPLOYED_AMM_ADDRESS
NEXT_PUBLIC_STAKING_ADDRESS=0x_DEPLOYED_STAKING_ADDRESS
